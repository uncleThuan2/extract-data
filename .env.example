# --- Required ---
# Choose AI provider: "openai", "gemini", or "copilot"
AI_PROVIDER=gemini

# --- OpenAI (dùng khi AI_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# --- Recommended combo: Gemini chat + Jina embed (cả hai đều miễn phí) ---
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# LLM_MODEL=gemini-2.0-flash
# EMBED_PROVIDER=jina
# JINA_API_KEY=jina_your-key-here
# EMBEDDING_DIMENSION=768

# --- Google Gemini FREE (chat + embed, dùng khi AI_PROVIDER=gemini) ---
# Lấy key miễn phí tại https://aistudio.google.com
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# --- Jina AI FREE embedding (thay thế Gemini embed, không giới hạn RPM) ---
# Lấy key miễn phí tại https://jina.ai/embeddings
# Khi dùng EMBED_PROVIDER=jina, AI_PROVIDER chỉ dùng cho chat
# EMBED_PROVIDER=jina
# JINA_API_KEY=jina_your-key-here

# --- GitHub Copilot (dùng khi AI_PROVIDER=copilot) ---
# Yêu cầu: có GitHub Copilot subscription
# Lấy token tại: https://github.com/settings/tokens (chọn scope: models:read)
# GITHUB_TOKEN=ghp_your-github-token-here
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# --- Bot Token ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Supabase (Free tier: https://supabase.com) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Optional ---
# HTTP port for health server (Render injects PORT automatically)
PORT=8080

# OpenAI model for chat (default: gpt-4o-mini for cost efficiency)
# LLM_MODEL=gpt-4o-mini
# Embedding model
# EMBEDDING_MODEL=text-embedding-3-small
# Chunk size for splitting PDF text
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
