# =============================================================================
# Document Q&A Telegram Bot – Biến môi trường
# =============================================================================
# Điền đầy đủ các biến BẮT BUỘC, các biến OPTIONAL có thể bỏ qua.
# Copy file này thành .env rồi điền giá trị thực vào.
# =============================================================================


# =============================================================================
# [BẮT BUỘC] CHAT PROVIDERS – thứ tự ưu tiên, tự động fallback khi hết quota
# Ví dụ: groq hết 14,400 req/ngày → tự chuyển sang gemini
# =============================================================================
CHAT_PROVIDERS=groq,gemini


# -----------------------------------------------------------------------------
# GROQ – ưu tiên 1 (miễn phí, không cần thẻ, 14,400 req/ngày)
# Đăng ký & lấy key tại: https://console.groq.com → API Keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here
GROQ_LLM_MODEL=llama-3.1-8b-instant
# Model thông minh hơn nhưng ít quota hơn (1,000 req/ngày):
# GROQ_LLM_MODEL=llama-3.3-70b-versatile


# -----------------------------------------------------------------------------
# GEMINI – ưu tiên 2 / fallback (miễn phí, 1,500 req/ngày)
# Đăng ký & lấy key tại: https://aistudio.google.com
# Muốn thêm quota: thêm key từ các Google account khác (mỗi account = quota riêng)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_API_KEY_2=your-gemini-key-account-2
# GEMINI_API_KEY_3=your-gemini-key-account-3
GEMINI_LLM_MODEL=gemini-2.0-flash-lite


# =============================================================================
# [BẮT BUỘC] EMBEDDING – Jina AI (miễn phí 1M tokens/tháng, không giới hạn RPM)
# Đăng ký & lấy key tại: https://jina.ai/embeddings
# QUAN TRỌNG: EMBEDDING_DIMENSION phải khớp với collection đã tạo trong Supabase
# =============================================================================
EMBED_PROVIDER=jina
JINA_API_KEY=your-jina-api-key-here
EMBEDDING_DIMENSION=768


# =============================================================================
# [BẮT BUỘC] TELEGRAM BOT
# Lấy token từ @BotFather trên Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here


# =============================================================================
# [BẮT BUỘC] SUPABASE
# Lấy tại: Settings → API (URL + anon key)
#           Settings → Database → Connection string URI (thay [YOUR-PASSWORD])
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres


# =============================================================================
# [OPTIONAL] Cài đặt xử lý tài liệu
# =============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# PORT=8080   # Render tự inject, không cần đặt thủ công
DB_SCHEMA=vecs  # Schema nơi vecs tạo bảng (mặc định: "vecs", set thành "public" nếu cần)
